COMPOSE_PROJECT_NAME=leadscope-ai

API_IMAGE=ghcr.io/yusufjojeh/prospectiq-api:latest
WEB_IMAGE=ghcr.io/yusufjojeh/prospectiq-web:latest

MARIADB_DATABASE=prospectiq
MARIADB_USER=prospectiq
MARIADB_PASSWORD=replace-me
MARIADB_ROOT_PASSWORD=replace-root-me

APP_NAME="LeadScope AI API"
APP_ENV=production
API_V1_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://prospectiq:replace-me@db:3306/prospectiq
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=120
WEB_ORIGIN=https://leadscope.example.com
WEB_ORIGINS=https://leadscope.example.com
SQL_ECHO=false
LOG_LEVEL=INFO
ENABLE_DB_HEALTHCHECK=true
ENABLE_REQUEST_LOGGING=true
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-admin-password
DEFAULT_ADMIN_NAME="LeadScope AI Admin"
DEFAULT_WORKSPACE_PUBLIC_ID=ws_default
DEFAULT_WORKSPACE_NAME="Default Workspace"

SERPAPI_API_KEY=replace-with-serpapi-key
SERPAPI_BASE_URL=https://serpapi.com/search.json

AI_PROVIDER=stub
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

API_PORT=8000
API_WEB_CONCURRENCY=2
RUN_MIGRATIONS=1

WEB_PORT=80
API_UPSTREAM=http://api:8000
WEB_PUBLIC_API_BASE_URL=
