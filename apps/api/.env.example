APP_NAME=LeadScope AI API
APP_ENV=development
API_V1_PREFIX=/api/v1

# Start MariaDB first: docker compose -f ../../infra/docker-compose.yml up -d
DATABASE_URL=mysql+pymysql://prospectiq:prospectiq@127.0.0.1:3306/prospectiq

# Local development secret (replace for shared/staging/prod environments).
JWT_SECRET=local-dev-jwt-secret-please-override-before-sharing-2026
JWT_EXPIRE_MINUTES=120
WEB_ORIGIN=http://localhost:5173
WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SQL_ECHO=false
LOG_LEVEL=INFO
ENABLE_DB_HEALTHCHECK=true
ENABLE_REQUEST_LOGGING=true
DEFAULT_ADMIN_EMAIL=admin@prospectiq.dev
DEFAULT_ADMIN_PASSWORD=local-dev-admin-password-rotate-before-sharing
DEFAULT_ADMIN_NAME=LeadScope AI Admin
DEFAULT_WORKSPACE_PUBLIC_ID=ws_default
DEFAULT_WORKSPACE_NAME=Default Workspace

# Optional in local demo mode. Required only for live provider calls.
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search.json
# auto = live if key exists, otherwise demo when ALLOW_DEMO_FALLBACKS=true
# live = require real SerpAPI credentials
# demo = force structured demo payloads even when a real key exists
# Use explicit demo mode by default for clean local startup without external provider dependency.
SERPAPI_RUNTIME_MODE=demo

# For presentation demos, keep AI_PROVIDER=stub unless you explicitly want a live provider.
AI_PROVIDER=stub
ALLOW_DEMO_FALLBACKS=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
