APP_NAME=ProspectIQ API
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://prospectiq:prospectiq@127.0.0.1:3306/prospectiq
JWT_SECRET=<replace-me>
JWT_EXPIRE_MINUTES=120
WEB_ORIGIN=http://localhost:5173
SQL_ECHO=false
LOG_LEVEL=INFO
ENABLE_DB_HEALTHCHECK=true
ENABLE_REQUEST_LOGGING=true
DEFAULT_ADMIN_EMAIL=admin@prospectiq.local
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_NAME=ProspectIQ Admin
DEFAULT_WORKSPACE_PUBLIC_ID=ws_default
DEFAULT_WORKSPACE_NAME=Default Workspace

SERPAPI_API_KEY=<replace-me>
SERPAPI_BASE_URL=https://serpapi.com/search.json

AI_PROVIDER=stub
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
