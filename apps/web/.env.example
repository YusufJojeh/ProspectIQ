# API origin for browser requests. Must match backend CORS (see apps/api .env WEB_ORIGIN / WEB_ORIGINS).
# Dev: default uvicorn on port 8000; frontend calls paths like /api/v1/... against this base.
VITE_API_BASE_URL=http://localhost:8000

# Production same-origin (Nginx proxy /api to API): set to empty string in build args / runtime-config.
# VITE_API_BASE_URL=
